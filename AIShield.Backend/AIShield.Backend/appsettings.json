{
  "ConnectionStrings": {
    "DefaultConnection": "Server=YOUR_SERVER;Database=AIShieldDB;User Id=YOUR_USER;Password=YOUR_PASSWORD;TrustServerCertificate=True;"
  },

  "RateLimiting": {
    "PermitLimit": 60,
    "WindowSeconds": 60
  },

  "Jwt": {
    "Secret": "REPLACE_WITH_A_LONG_RANDOM_SECRET",
    "ExpireHours": 8
  },

  "GuardAlgorithms": {
    "Memory": {
      "HalfLifeDays": 30,
      "ForgetThreshold": 0.1,
      "ConflictPenaltyWeight": 0.6,
      "SimilarityCandidateThreshold": 0.75
    },
    "Rag": {
      "MinimumScore": 0.2,
      "TrustScores": {
        "system": 1.0,
        "admin": 0.9,
        "user": 0.7,
        "unknown": 0.5
      }
    },
    "TopicDrift": {
      "MaxConsecutiveDrift": 3,
      "SimilarityThreshold": 0.12,
      "MinimumSegmentLength": 8
    }
  },

  "Admin": {
    "Password": "REPLACE_WITH_ADMIN_PASSWORD"
  },

  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },

  "AllowedHosts": "*"
}
