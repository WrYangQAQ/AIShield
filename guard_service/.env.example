# ============================================================================
# CuteBlogGuard 环境变量配置
# 复制为 .env 后按需修改
# ============================================================================

# ---- 服务基础 ----
GUARD_SERVICE_API_KEY=
# 服务级鉴权密钥。设置后所有 /guard/* 请求必须携带 X-Guard-Key 头。
# 留空则不鉴权（仅限内网/开发环境）。
# 示例：GUARD_SERVICE_API_KEY=sk-guard-xxxx

GUARD_CORS_ORIGINS=*
# CORS 允许的来源，多个用逗号分隔。
# 生产建议限制为具体域名：https://yourblog.com,https://admin.yourblog.com

# ---- OpenAI API ----
OPENAI_API_KEY=
# OpenAI API Key。用于语义审核（Moderation API）和向量嵌入（Embeddings API）。
# 留空则仅用规则快筛，无语义审核能力。

OPENAI_BASE_URL=https://api.openai.com/v1
# OpenAI API 端点。可改为兼容接口（如 DeepSeek、Azure OpenAI）。

# ---- Embedding 模式 ----
EMBEDDING_API_KEY=
# Embedding 专用 API Key。设置后优先使用远程 Embedding API（无 GIL 问题）。
# 留空则回退到 OPENAI_API_KEY；两者都为空则使用本地 fastembed（子进程隔离 GIL）。

# ---- 护栏配置 ----
GUARD_STRICT_MODE=true
# 严格模式（Fail-Closed）。true=关键依赖缺失/异常时阻断，false=放行但标记 degraded。

GUARD_MAX_FIELD_LENGTH=100
# 结构化字段最大长度（字符数），防超长输入 DoS。

GUARD_DECAY_RATE=0.1
# 记忆衰减速率。decay_factor = exp(-rate × hours_since_ref)。
# 0.1 表示约10小时未引用→置信度降至37%。

GUARD_FORGET_THRESHOLD=0.1
# 记忆遗忘阈值。置信度低于此值时触发归档。

GUARD_MAX_CONSECUTIVE_DRIFT=3
# 主题漂移阈值。连续N个片段无锚点时判定为漂移。

GUARD_STREAMING_SAMPLE_RATE=3
# 流式检测采样率（低风险区间）。每N个缓冲块检测1次，高风险区间逐块必检。

GUARD_SAFE_RERANK_THRESHOLD=0.2
# RAG 重排阈值。相关性×信任权重 < 阈值 → 丢弃候选文档。

GUARD_AUDIT_SNIPPET_LENGTH=50
# 审计日志内容截断长度（字符数）。不存完整明文。

# ---- 记忆冲突检测 ----
GUARD_CONFLICT_SIMILARITY_THRESHOLD=0.75
# 冲突语义相似度阈值。新记忆与旧记忆余弦相似度 >= 此值且内容不同 → 视为冲突。
# 实测参考(bge-small-zh-v1.5)：学英语vs学德语≈0.80，学英语vs学Python≈0.62。
# 0.75 可区分同领域冲突与跨领域不冲突。

GUARD_CONFLICT_PENALTY_WEIGHT=0.6
# 冲突降权惩罚权重。new_confidence = old_confidence × (1 - penalty_weight)。
# 0.6 表示降为原来的40%。

# ---- 信任等级预配置 ----
GUARD_TRUST_LEVELS=
# 预加载的信任等级映射。格式：key1:level1,key2:level2
# 示例：GUARD_TRUST_LEVELS=sk-admin:admin,sk-user:user
# 等级可选：system > admin > user > untrusted

# ---- 审计文件落盘 ----
GUARD_AUDIT_FILE_PATH=
# 审计日志 JSONL 文件路径。留空则只存内存。
# 示例：GUARD_AUDIT_FILE_PATH=/var/log/guard_audit.jsonl
